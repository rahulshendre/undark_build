# Undark — environment.
# Copy to .env.local and fill in. Only ANTHROPIC_API_KEY is required to run.

# Required — the intelligence layer.
ANTHROPIC_API_KEY=

# Optional — Supabase persistence. Leave blank to use local JSON (.data/cases).
# Create the table once:
#   create table cases (id text primary key, created_at timestamptz default now(), data jsonb not null);
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only; falls back to the anon key if unset.
SUPABASE_SERVICE_ROLE_KEY=
